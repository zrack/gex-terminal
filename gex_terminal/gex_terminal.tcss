Screen {
    background: #080a0d;
    color: #e9eef3;
}

Header {
    background: #0c1015;
    color: #e9eef3;
    text-style: bold;
}

Footer {
    background: #0c1015;
    color: #94a3b8;
}

#dashboard {
    height: 1fr;
    layout: grid;
    grid-size: 3 4;
    grid-columns: 20 1fr 40;
    grid-rows: 9 1fr 10 7;
    background: #080a0d;
}

#sidebar {
    row-span: 4;
    border-right: solid #26313d;
    background: #0b0f14;
    padding: 1;
}

#top-metrics {
    column-span: 2;
    layout: grid;
    grid-size: 6 1;
    grid-columns: 1fr 1fr 1fr 1fr 1fr 1fr;
    grid-rows: 1fr;
    grid-gutter: 1;
    padding: 1;
    border-bottom: solid #26313d;
    background: #10151b;
}

#matrix-panel {
    border-right: solid #26313d;
    padding: 1 2;
    background: #0d1218;
}

#structure-panel {
    padding: 1 2;
    background: #0d1218;
}

#flow-panel {
    border-top: solid #26313d;
    border-right: solid #26313d;
    padding: 1 2;
    background: #0d1218;
}

#quality-panel {
    border-top: solid #26313d;
    padding: 1 2;
    background: #0d1218;
}

#event-panel {
    column-span: 2;
    border-top: solid #26313d;
    padding: 1 2;
    background: #0d1218;
}

.section-title {
    height: 1;
    color: #e9eef3;
    text-style: bold;
}

.subtle {
    color: #94a3b8;
}

.rail-label {
    color: #64748b;
    text-style: bold;
    margin-top: 1;
    margin-bottom: 1;
}

.symbol {
    height: 3;
    border: solid #1d252e;
    background: #111820;
    margin-bottom: 1;
    padding: 0 1;
    content-align: center middle;
    text-style: bold;
}

.symbol-active {
    border: solid #38bdf8;
    background: #122230;
}

.feed-line {
    height: 3;
    color: #94a3b8;
}

.metric-card {
    border: round #232e3a;
    background: #131a22;
    padding: 0 1;
    height: 100%;
}

.metric-label {
    height: 1;
    color: #8a97a6;
    text-style: bold;
}

.metric-value {
    height: 1;
    text-style: bold;
    color: #f1f5f9;
    margin-top: 1;
}

.metric-foot {
    height: 1;
    color: #64748b;
}

.green {
    color: #4ade80;
}

.red {
    color: #fb7185;
}

.amber {
    color: #fbbf24;
}

.cyan {
    color: #38bdf8;
}

.zone-card {
    height: 5;
    border: round #232e3a;
    background: #10151b;
    margin-bottom: 1;
    padding: 0 1;
}

.regime-card {
    height: 6;
    border: round #232e3a;
    background: #10151b;
    padding: 0 1;
}

.quality-card {
    height: 6;
    border: round #232e3a;
    background: #10151b;
    padding: 0 1;
}

.zone-value {
    text-style: bold;
}

.event-line {
    height: 1;
    color: #94a3b8;
}

.state-banner {
    height: 1;
    text-style: bold;
    margin-bottom: 1;
}

#status-bar {
    height: 1;
    background: #0c1015;
    color: #94a3b8;
    padding: 0 1;
}

DataTable {
    height: 1fr;
    background: #0d1218;
}

DataTable > .datatable--header {
    background: #10151b;
    color: #94a3b8;
    text-style: bold;
}

Sparkline {
    height: 5;
    margin-top: 1;
}
